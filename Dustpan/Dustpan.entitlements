<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Intentionally NOT sandboxed: a real cleaner needs Full Disk Access to scan
	     ~/Library, caches, and app leftovers. Full Disk Access is incompatible with
	     the App Sandbox, which is why this app is direct-distributed (notarized DMG +
	     Homebrew Cask) and not on the Mac App Store. See PRD.md §7. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!-- Apple Events to Finder only: root-owned /Applications bundles are
	     trashed by Finder so macOS can show its admin-authorization popup
	     in-app. Required under the hardened runtime for notarized builds. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
